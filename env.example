# Headless voicebox environment. Two ways to supply these:
#   a) export them in your shell before `docker compose -f docker-compose.headless.yml up`
#   b) copy this file to .env (gitignored) if your tooling permits
# Every REST route and /mcp require:  Authorization: Bearer <VOICEBOX_API_KEY>
# Generate a key:  openssl rand -hex 24
VOICEBOX_API_KEY=replace-with-a-long-random-string

# Host port the container is published on (127.0.0.1 only)
VOICEBOX_HOST_PORT=17600
